{
  "name": "lm-event-resolution",
  "version": "0.1.0",
  "description": "Event relationship and forecast repository — SQLite-backed graph of events, sub-factors, resolution drivers, monitors, and scenarios with full source/update/status/dependency tracking and FTS5 search",
